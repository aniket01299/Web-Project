.left{
    position: relative;
    width: 30%;
}
.left img:nth-child(1){
width: 460px;
animation: gm  0.5s ease-in-out;

}
@keyframes gm {
    0%{
       transform:translateY(50px);
    }
    100%{
         transform:translateY(0px);
    }
}

.left img:nth-child(2){
    position: absolute;
    right: 90px;
    top: 15px;
    width: 450px;
    animation: dil 1s ease-in-out;

}
@keyframes dil {
    0%{
       opacity: 0;
    }
    75%{
        opacity: 0;
    }
    100%{
        opacity: 1;
    }
}

.left img:nth-child(3){
    margin-left: 20px;
width: 420px;
animation: chai 1.8s ease-in-out;

}
@keyframes chai {
    0%{
        opacity: 0;
        transform: translateY(50px);
    }
    60%{
        opacity: 0;
       
    }
    100%{
        opacity: 1;
         transform: translateY(0px);
    }
}

.left img:nth-child(4){
width: 450px;
animation: voice 2.1s ease-in-out;
}
@keyframes voice {
    0%{
        opacity: 0;
        transform: translateY(70px);
    }
    80%{
        opacity: 0;
    }
    100%{
        opacity: 1;
        transform: translateY(0);
    }
    
}

.left img:nth-child(5){
width: 450px;
animation: emo 3.1s ease-in-out;


}
@keyframes emo {
    0%{
        opacity: 0;
        transform: translateY(70px);
    }
    80%{
        opacity: 0;
    }
    100%{
        opacity: 1;
        transform: translateY(0);
    }
}
.left img:nth-child(6){
    position: absolute;
    top: 470px;
    right: 90px;
width: 450px;
animation: emotionalemoji 3.6s ease-in-out;
}
@keyframes emotionalemoji {
    0%{
        opacity: 0;
  
    }
    75%{
        opacity: 0;
    }
    100%{
        opacity: 1;
      
    }
}
.left img:nth-child(7){
width: 450px;
animation: trip 4s ease-in-out;
}
@keyframes trip {
    0%{
        opacity: 0;
        transform: translateY(70px);
    }
    80%{
        opacity: 0;
    }
    100%{
        opacity: 1;
        transform: translateY(0px);
    }
}
