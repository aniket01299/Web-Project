*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}  

.container{
    overflow: hidden;
   width: 100vw;
   min-height: 100vh;
   background-color: #fcf5eb;
}
  
.navbar{
    width: 100%;
    height: 10%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 30px;
    position: sticky;
    top: 0;
   
    
}
.leftnav > img {
    width: 180px;
    height: 60%;

}
.features{
    position:relative;
    cursor: pointer;
    display: flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
   
}
.features::after{
    position:absolute;
    content:"";
    width: 100%;
    height: 3px;
    left:0%;
    bottom:0%;
    background-color: #25d366;
    transform: scaleX(0);
    transition: all 0.5s ease-in-out;
    transform-origin:left;
    
}
.features:hover::after{
    transform: scaleX(1);
}

.features > img{
    width: 60%;
    height: 80%;
 transform: rotate(-90deg);
}
.featuresitems{
   position: relative;
   display: flex;
   gap: 50px;
   font-size: 18px;
   font-weight: bold; 
}
.featuresitems > p{
    position: relative;
    cursor: pointer;
}

.featuresitems > p::after{
    position:absolute;
    content:"";
    width: 100%;
    height: 3px;
    left:0%;
    bottom:0%;
    background-color: #25d366;
    transform: scaleX(0);
    transition: all 0.5s ease-in-out;
    transform-origin:left;
    
}
.featuresitems > p:hover::after{
    transform: scaleX(1);}

 

.navbar > button{
    width:8%;
    height: 50px;
    border-radius: 30px;
    background-color: #25d366;
}

